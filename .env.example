PORT=5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/heathaven

# JWT
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

# CORS (optional)
# Comma-separated origins
CORS_ORIGIN=http://localhost:5500,http://localhost:5000

# Seed admin (used by utils/seed.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=HeatHaven Admin

